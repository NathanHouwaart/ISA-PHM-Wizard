{
  "name": "ISA-PHM-Wizard",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "homepage": "https://NathanHouwaart.github.io/ISA-PHM-Wizard",
  "scripts": {
    "predeploy": "npm run build",
    "deploy": "gh-pages -d dist",
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint .",
    "test": "vitest",
    "test:run": "vitest --run",
    "test:unit": "vitest --run --exclude src/tests/backend-*.test.js --exclude src/tests/conversion-payload.contract.test.js",
    "test:contract": "vitest --run src/tests/conversion-payload.contract.test.js",
    "test:integration": "vitest --run src/tests/backend-conversion.test.js src/tests/backend-root.test.js",
    "preview": "vite preview"
  },
  "dependencies": {
    "@esbuild-plugins/node-globals-polyfill": "^0.2.3",
    "@esbuild-plugins/node-modules-polyfill": "^0.2.2",
    "@radix-ui/react-alert-dialog": "^1.1.14",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-switch": "^1.2.5",
    "@radix-ui/react-tooltip": "^1.2.7",
    "@revolist/react-datagrid": "^4.15.8",
    "@revolist/revogrid": "^4.15.8",
    "@revolist/revogrid-column-date": "^2.0.25",
    "@revolist/revogrid-column-select": "^3.1.9",
    "@tailwindcss/vite": "^4.1.10",
    "browser-fs-access": "^0.38.0",
    "buffer": "^6.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dexie": "^3.2.2",
    "fuse.js": "^7.1.0",
    "lucide-react": "^0.513.0",
